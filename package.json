{
  "name": "aidc-work",
  "version": "0.1.5",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3163",
    "dev:fresh": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && prisma migrate deploy && next build",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "start": "next start -p 3163",
    "lint": "next lint",
    "check:links": "node ./scripts/check-internal-links.mjs",
    "release:patch": "npm version patch --no-git-tag-version",
    "docker:build": "docker build -t aidc-work:latest .",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^5.22.0",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.78.0",
    "resend": "^6.12.4",
    "zod": "^4.4.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.5.3",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
