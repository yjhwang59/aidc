# PostgreSQL connection string
# Supabase users should prefer the Session Pooler URL for IPv4-compatible runtimes.
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Session signing secret (32+ characters)
SESSION_SECRET=your-random-secret-at-least-32-characters-long

# Admin credentials (server-side only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password

# Resend email (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
NOTIFICATION_FROM_EMAIL=bookings@aidc.work
NOTIFICATION_TO_EMAIL=yjhwang59@gmail.com

# Optional: seed demo availability slots
# SEED_DEMO_SLOTS=true
